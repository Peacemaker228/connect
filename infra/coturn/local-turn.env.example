# Local-only TURN credential prototype values.
# Do not use these placeholder values in production.

LOCAL_TURN_URLS=turn:127.0.0.1:3478?transport=udp,turn:127.0.0.1:3478?transport=tcp
LOCAL_TURN_STATIC_AUTH_SECRET=replace-with-random-local-secret
LOCAL_TURN_TTL_SECONDS=600

# Optional local Docker coturn knobs.
# Keep these values local-only; production TURN ports and secrets need a separate runbook.
LOCAL_TURN_EXTERNAL_IP=127.0.0.1
LOCAL_TURN_RELAY_MIN_PORT=49160
LOCAL_TURN_RELAY_MAX_PORT=49170
