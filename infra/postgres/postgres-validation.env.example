# Local Postgres validation only.
# Do not use these variables as the active application DATABASE_URL.

POSTGRES_VALIDATION_DB=connect_validation
POSTGRES_VALIDATION_USER=connect_validation
POSTGRES_VALIDATION_PASSWORD=connect_validation_password
POSTGRES_VALIDATION_PORT=5433

POSTGRES_VALIDATION_DATABASE_URL=postgresql://connect_validation:connect_validation_password@localhost:5433/connect_validation?schema=public
POSTGRES_VALIDATION_SHADOW_DATABASE_URL=postgresql://connect_validation:connect_validation_password@localhost:5433/connect_validation_shadow?schema=public
