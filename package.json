{
  "name": "ax-connect",
  "version": "0.0.2",
  "type": "module",
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "prepare:desktop:build-info": "node electron/generate-build-info.mjs",
    "dev:front": "next dev -p 3001",
    "dev:back": "bun run build:server && node dist/server.js",
    "dev:api": "ts-node --project apps/api/tsconfig.json apps/api/src/main.ts",
    "dev:full": "concurrently \"bun run dev:back\" \"bun run dev:front\"",
    "dev:desktop:web": "bun next dev -p 3005",
    "dev:desktop:app": "bun run prepare:desktop:build-info && node electron/dev-launcher.mjs",
    "dev:desktop": "concurrently \"bun run dev:desktop:web\" \"bun run dev:desktop:app\"",
    "electron": "bun run prepare:desktop:build-info && electron .",
    "dev": "bun next dev",
    "build:api": "tsc -p apps/api/tsconfig.build.json",
    "build:web": "bun next build",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "bun run build:web && bun run build:server",
    "start:api": "node apps/api/dist/main.js",
    "start:web": "bun next start -p 3000",
    "start:back": "node dist/server.js",
    "start:desktop": "bun run prepare:desktop:build-info && electron .",
    "typecheck:api": "tsc --noEmit -p apps/api/tsconfig.json",
    "clean:desktop": "node -e \"require('fs').rmSync('dist-desktop', { recursive: true, force: true })\"",
    "check:desktop:config": "node electron/validate-production-config.mjs",
    "build:desktop": "bun run prepare:desktop:build-info && bun run clean:desktop && electron-builder --publish never",
    "release:desktop": "bun run check:desktop:config && bun run build:desktop",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:reset": "prisma migrate reset",
    "prisma:dbpush": "prisma db push",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@hookform/resolvers": "^3.9.1",
    "@livekit/components-react": "^2.6.7",
    "@livekit/components-styles": "^1.1.4",
    "@nestjs/common": "^11.1.9",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.9",
    "@nestjs/platform-express": "^11.1.9",
    "@nestjs/platform-socket.io": "^11.1.9",
    "@nestjs/websockets": "^11.1.9",
    "@prisma/client": "5.22.0",
    "@radix-ui/react-avatar": "^1.1.1",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.1.3",
    "@svgr/webpack": "^8.1.0",
    "@tanstack/react-query": "^5.60.4",
    "@types/js-cookie": "^3.0.6",
    "axios": "^1.7.7",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "1.0.0",
    "date-fns": "^4.1.0",
    "emoji-mart": "^5.6.0",
    "install": "^0.13.0",
    "js-cookie": "^3.0.5",
    "livekit-server-sdk": "^2.8.1",
    "lucide-react": "^0.453.0",
    "next": "14.2.15",
    "next-intl": "^3.26.3",
    "next-themes": "^0.3.0",
    "query-string": "^9.1.1",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.53.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "shadcn": "^2.1.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^11.0.2",
    "zod": "^3.23.8",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.0",
    "electron": "^37.0.0",
    "electron-builder": "^26.0.12",
    "eslint": "^8",
    "eslint-config-next": "15.0.1",
    "postcss": "^8",
    "prettier": "^3.3.3",
    "prisma": "5.22.0",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "build": {
    "appId": "com.axconnect.desktop",
    "productName": "AxConnect",
    "icon": "electron/assets/icon.ico",
    "protocols": [
      {
        "name": "AxConnect",
        "schemes": [
          "axconnect"
        ]
      }
    ],
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "directories": {
      "app": "electron",
      "output": "dist-desktop"
    },
    "files": [
      "**/*"
    ],
    "win": {
      "icon": "electron/assets/icon.ico",
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
